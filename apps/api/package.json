{
  "name": "@rapidtriage/api",
  "version": "1.0.0",
  "description": "RapidTriage EMS sync API (Express + PostgreSQL + Drizzle)",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --runInBand",
    "lint": "eslint \"src/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@rapidtriage/shared": "*",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.36.4",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.10",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@eslint/js": "^9.25.0",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.25.0",
    "globals": "^15.9.0",
    "typescript-eslint": "^8.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "tsx": "^4.16.2",
    "typescript": "~5.9.2"
  }
}
