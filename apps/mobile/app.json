{
  "expo": {
    "name": "RapidTriage EMS",
    "slug": "rapidtriage-ems",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rapidtriage",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rapidtriage.ems"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.rapidtriage.ems"
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "26c6c331-2590-469f-a853-2c8ff1d1b932"
      }
    },
    "owner": "ericokim"
  }
}
